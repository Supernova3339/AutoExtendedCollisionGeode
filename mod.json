{
	"geode": "5.4.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "superdev.auto_extended_collision",
	"name": "Auto Extended Collision",
	"version": "v1.0.1",
	"developers": [
		"Supernova3339"
	],
	"description": "Activate extended collissions automatically",
	"dependencies": {
		"geode.node-ids": ">=1.0.0"
	},
	"tags": [
		"editor",
		"utility",
		"offline"
	],
	"settings": {
		"enabled": {
			"name": "Enabled",
			"type": "bool",
			"default": true
		},
		"toggle": {
			"name": "Toggle Mod",
			"type": "keybind",
			"default": "Ctrl+L"
		},
		"threshold": {
			"name": "Scale Threshold",
			"type": "float",
			"default": 4.0,
			"max": 12.0,
			"min": 0.0,
			"control": {
				"arrows": true,
				"arrow-step": 0.1,
				"slider": true,
				"slider-step": 0.01
			}
		}
	}
}